#compdef decb

# _decb - Active Zsh completion script for decb

local -a subcommands
local -a global_opts

# 1. Define global flags
global_opts=(
    '(-h -?)'{-h,-?}'[Show help message]'
    '-g[Set Ganule Count]'
)

# 2. Actively query the decb binary for its subcommands
# _call_program is a safe Zsh built-in that executes commands in the user's PATH
subcommands=(${(f)"$(_call_program decb-commands decb __complete 2>/dev/null)"})

_arguments -C \
    $global_opts \
    '1:subcommand:compadd -a subcommands' \
    '*:file:_files -g "*.(wav|WAV|cas|CAS|c10|C10|dsk|os9|DSK|OS9)"'

